# Copy to deploy/.env and adjust. install-vps.sh generates one automatically
# with random secrets if deploy/.env does not exist.

# Django
DJANGO_SECRET_KEY=change-me
# not_production_settings = no real emails, permissive hosts (good for demo/staging).
# Switch to contentcuration.settings for real production (requires email config).
DJANGO_SETTINGS_MODULE=contentcuration.not_production_settings

# Port the app is published on (behind your reverse proxy / firewall)
STUDIO_HTTP_PORT=8080

# PostgreSQL
POSTGRES_USER=learningequality
POSTGRES_DB=kolibri-studio
POSTGRES_PASSWORD=change-me

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=studio
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=content

CELERY_TIMEZONE=UTC
