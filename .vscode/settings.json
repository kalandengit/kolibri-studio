{
  "python.defaultInterpreterPath": "${env:USERPROFILE}\\kolibri-studio-env\\venv\\Scripts\\python.exe",
  "python.terminal.activateEnvironment": true,
  "eslint.validate": ["javascript", "vue"],
  "files.eol": "\n",
  "[powershell]": { "files.eol": "\r\n" },
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "contentcuration/build": true,
    "contentcuration/contentcuration/static/js/bundles": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true
  },
  "terminal.integrated.env.windows": {
    "PATH": "${env:USERPROFILE}\\kolibri-studio-env\\node;${env:PATH}",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
    "DJANGO_SETTINGS_MODULE": "contentcuration.dev_settings"
  }
}
